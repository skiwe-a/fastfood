# ============================================================
# FASTfood EFS Platform Lite — Environment Variables
# Neon + Upstash + Supabase (100% Free, works from Sudan)
# ============================================================

# ===========================
# Database — Neon PostgreSQL
# Copy your connection string from Neon Dashboard
# ===========================
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ===========================
# NextAuth — Required
# Generate a secret: openssl rand -base64 48
# ===========================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-secret-with-openssl-rand-base64-48

# ===========================
# Upstash Redis
# Copy from: https://console.upstash.com/redis
# ===========================
REDIS_URL=https://your-redis.upstash.io
REDIS_TOKEN=your-redis-token

# ===========================
# Supabase Storage
# Copy from: https://app.supabase.com/project/_/settings/api
# ===========================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_SERVICE_KEY=your-service-role-key

# ===========================
# Optional — Allowed Origins for CSRF
# ===========================
ALLOWED_ORIGINS=http://localhost:3000

# ===========================
# Optional — Supabase Storage Bucket Name
# Default: fastfood-media (create this bucket in Supabase)
# ===========================
# SUPABASE_STORAGE_BUCKET=fastfood-media
